# =============================================================================
# ReLoop: .gitignore
# =============================================================================

# --- 1. Python Internals ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- 2. Virtual Environments ---
venv/
.venv/
.venv312/
env/
.env/

# --- 3. Environment Secrets (NEVER commit actual .env files) ---
.env
.env.local
.env.production
.env.staging
# Exception: commit the example template
!.env.example

# --- 4. Runtime Data & Logs ---
data/feedback_log.json
data/processed/
*.log
logs/

# --- 5. Local Databases ---
qdrant_db/

# --- 6. Temporary Uploads & AI Outputs ---
temp_uploads/
static/          # Built frontend (generated by npm run build)

# --- 7. Heavy AI Models (downloaded at runtime) ---
*.pt
*.onnx
*.bin
*.safetensors

# --- 8. Frontend Build Artifacts ---
frontend/node_modules/
frontend/dist/
node_modules/
dist/

# --- 9. IDE & OS Junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- 10. AWS Sensitive Files ---
*.pem
*.key

# --- 11. Research & Development ---
R&D/